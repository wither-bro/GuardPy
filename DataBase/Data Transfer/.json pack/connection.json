{
  "connection_meta": {
    "version": "1.0.0",
    "protocol_stack": "tcp_raw",
    "keep_alive": true
  },
  "socket_config": {
    "ip_binding": "0.0.0.0",
    "port": 9000,
    "tcp_nodelay": true,
    "so_reuseaddr": true,
    "backlog": 1024
  },
  "buffer_config": {
    "send_buffer": 65536,
    "receive_buffer": 65536,
    "zero_copy_enabled": true
  },
  "flow_control": {
    "max_concurrent_connections": 500,
    "read_timeout_us": 1000,
    "write_timeout_us": 1000
  },
  "security": {
    "handshake_enabled": false,
    "auth_token_required": true,
    "encryption": "none"
  }
}
