// Data Base/Bibliotics/Zig Requests/Pack/buffer.json
{
  "version": "5.0.0",
  "name": "ZigRequestsBuffer",
  "buffer_settings": {
    "size_limit": "1024MB",
    "flush_interval_ms": 500,
    "strategy": "fifo",
    "compression": {
      "enabled": true,
      "algorithm": "zstd"
    },
    "overflow_policy": "drop_oldest"
  }
}
