// Data Base/Bibliotics/Zig Requests/Clearing Tools/check.git
const std = @import("std");

pub const IntegrityChecker = struct {
    pub fn verify(file_path: []const u8) !void {
        const file = try std.fs.cwd().openFile(file_path, .{});
        defer file.close();

        const stat = try file.stat();
        std.debug.print("FILE_CHECK: {s}\nSize: {d} bytes\nStatus: Verified\n", .{ file_path, stat.size });
    }
};
